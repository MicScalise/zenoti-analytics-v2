# =============================================================================
# .env.example — Environment variable template for deployment
# Implements: EP §18, DR-043 (real RSA keys, not fabricated)
# =============================================================================

# PostgreSQL
POSTGRES_PASSWORD=za_dev_password

# Redis
REDIS_URL=redis://redis:6379

# Database connection
DATABASE_URL=postgresql://za:za_dev_password@postgres:5432/za_dev

# JWT RSA keys — base64-encoded PEM (use scripts/generate-test-keys.sh)
# DR-043: These MUST be real RSA keys, not fabricated placeholders
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=

# Zenoti API
ZENOTI_API_KEY=

# SendGrid (email notifications)
SENDGRID_API_KEY=
SENDGRID_TEMPLATE_WELCOME=
SENDGRID_TEMPLATE_PAYMENT_FAILURE=
SENDGRID_TEMPLATE_MFA_RESET=

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Application
NODE_ENV=production
PORT=3000
